11. Deterministic Decision Resolver

function resolveDecision(rules, event) {

  if (rules.length === 0) {
    return allow(event);
  }

  const primary = rules[0];

  let state = "flagged";
  let action = "report_required";

  if (primary.action === "block") {
    state = "blocked";
    action = "deny_transaction";
  }

  if (primary.action === "restrict") {
    state = "restricted";
    action = "kyc_required";
  }

  return {
    state,
    action,
    triggeredRuleId: primary.ruleId,
    idempotencyKey: sha256(
      `${event.eventId}:${rules.map(r => r.ruleId).join(":")}`
    ),
    timestamp: event.timestamp
  };
}


