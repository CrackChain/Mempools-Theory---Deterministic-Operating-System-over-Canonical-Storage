10. Core Evaluation Engine

function evaluate(event, identity, ruleSet, history, evidenceStore) {

  if (!verifyEventIntegrity(event, evidenceStore)) {
    return deny("SYS_CRYPT_FAIL", event);
  }

  if (identity.jurisdiction !== ruleSet.jurisdiction) {
    return deny("SYS_JURISDICTION_MISMATCH", event);
  }

  const rules = [...ruleSet.rules]
    .sort((a, b) => (a.priority ?? 0) - (b.priority ?? 0));

  const triggered = [];

  const totalVolume24h = aggregateVolume(
    history,
    event.entityId,
    event.timestamp
  );

  for (const rule of rules) {

    // AML (structuring-aware)
    if (rule.type === "threshold") {
      if (totalVolume24h > rule.conditionValue) {
        triggered.push(rule);
      }
    }

    // sanctions → hard stop
    if (rule.type === "sanctions") {
      if (identity.sanctionsCheck === "hit") {
        return resolveImmediate(rule, event);
      }
    }

    // KYC enforcement
    if (rule.type === "kyc_required") {
      if (
        identity.kycStatus !== "verified" ||
        (rule.conditionValue === "enhanced" && identity.kycLevel !== "enhanced")
      ) {
        triggered.push(rule);
      }
    }
  }

  return resolveDecision(triggered, event);
}


