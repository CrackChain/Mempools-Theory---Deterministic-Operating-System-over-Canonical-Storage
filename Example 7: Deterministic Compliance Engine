13. Privacy-safe Evidence (PII excluded)

function generateEvidence(event, identity, ruleSet, result) {

  const safeIdentity = {
    entityId: identity.entityId,
    jurisdiction: identity.jurisdiction,
    kycStatus: identity.kycStatus,
    riskScore: identity.riskScore
  };

  const decisionHash = sha256(canonicalize({
    event,
    safeIdentity,
    ruleSetHash: ruleSet.ruleSetHash,
    result
  }));

  return {
    eventId: event.eventId,
    decisionHash,
    result,
    timestamp: event.timestamp
  };
}


