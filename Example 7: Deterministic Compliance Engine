12. Immediate Blocking (critical path)

function resolveImmediate(rule, event) {

  return {
    state: "blocked",
    action: "deny_transaction",
    triggeredRuleId: rule.ruleId,
    idempotencyKey: sha256(`${event.eventId}:${rule.ruleId}`),
    timestamp: event.timestamp
  };
}


