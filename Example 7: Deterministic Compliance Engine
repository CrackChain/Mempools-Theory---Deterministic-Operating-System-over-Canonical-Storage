7. Trust Pipeline (cryptographic integrity)

function verifyEventIntegrity(event, evidenceStore) {

  const message = canonicalize({
    eventId: event.eventId,
    entityId: event.entityId,
    payload: event.payload,
    timestamp: event.timestamp,
    evidenceHash: event.evidenceHash,
    ruleSetHash: event.ruleSetHash
  });

  const sigValid = verifyEd25519(
    message,
    event.signature,
    event.publicKey
  );

  const evidenceValid = evidenceStore.has(event.evidenceHash);

  return sigValid && evidenceValid;
}


