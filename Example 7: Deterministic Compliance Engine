8. Deterministic Time Window (anti-structuring)

function computeWindow(anchorTimestamp) {

  const end = new Date(anchorTimestamp).getTime();
  const start = end - (24 * 60 * 60 * 1000);

  return { start, end };
}


---

9. Aggregated Volume (state-aware AML)

function aggregateVolume(events, entityId, anchorTimestamp) {

  const { start, end } = computeWindow(anchorTimestamp);

  return events
    .filter(e =>
      e.entityId === entityId &&
      new Date(e.timestamp).getTime() >= start &&
      new Date(e.timestamp).getTime() <= end
    )
    .reduce((acc, e) => acc + e.payload.amount, 0);
}


