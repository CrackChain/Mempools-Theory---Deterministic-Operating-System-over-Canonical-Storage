8. Deterministic execution engine

8.1 Pure function with enforced inputs

type State =
  | "draft"
  | "active"
  | "fulfilled"
  | "breached"
  | "closed"
  | "disputed"
  | "overridden";

function nextState(
  definition: ContractDefinition,
  currentState: State,
  event: ContractEvent,
  context: RuntimeContext
): State {

  // Reject if context is not verified
  if (!verifyContext(context)) return currentState;

  // Reject if evidence is not valid
  if (!verifyEvidence(event.evidenceHash)) return currentState;

  const transition = definition.transitions.find(
    (t) => t.from === currentState && t.event === event.type
  );

  if (!transition) return currentState;

  if (transition.conditions) {
    for (const cond of transition.conditions) {
      if (cond === "payment_received" && !context.paymentReceived) return currentState;
      if (cond === "service_verified" && !context.serviceVerified) return currentState;
    }
  }

  // Deterministic deadline check
  const deadline = definition.parameters.deadline as string;
  if (deadline && event.timestamp > deadline && currentState === "active") {
    return "breached";
  }

  return transition.to;
}


