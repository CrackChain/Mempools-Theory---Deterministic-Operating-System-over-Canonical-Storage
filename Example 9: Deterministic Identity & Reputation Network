6. Cryptographic Verification (Ed25519)

import nacl from "tweetnacl";

function verifySignature(message: string, signature: Uint8Array, publicKey: Uint8Array): boolean {
  return nacl.sign.detached.verify(
    Buffer.from(message),
    signature,
    publicKey
  );
}


