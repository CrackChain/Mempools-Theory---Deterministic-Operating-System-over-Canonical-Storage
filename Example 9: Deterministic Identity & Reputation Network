9. Reputation Score Engine (Deterministic)

function computeReputation(features: IdentityFeatures): number {

  const score =
    0.35 * features.success_rate +
    0.25 * (1 - features.dispute_rate) +
    0.15 * normalizeVolume(features.volume_30d) +
    0.15 * features.consistency_score +
    0.10 * (1 - features.anomaly_score);

  return Math.min(Math.max(score, 0), 1);
}


