11. Identity State Derivation

function deriveIdentityState(entityId: string, events: any[]) {

  const features = buildFeatures(events);
  const score = computeReputation(features);

  let riskLevel: "low" | "medium" | "high" = "low";

  if (score < 0.4) riskLevel = "high";
  else if (score < 0.7) riskLevel = "medium";

  return {
    entityId,
    reputationScore: Number(score.toFixed(4)),
    riskLevel,
    behaviorClass: score > 0.8 ? "stable" : "volatile",
    timestamp: new Date().toISOString(),
    stateHash: sha256(canonicalize({ entityId, features, score }))
  };
}


