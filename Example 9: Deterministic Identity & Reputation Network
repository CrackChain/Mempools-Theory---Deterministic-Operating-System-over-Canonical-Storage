7. Identity Event Validation Pipeline

function verifyIdentityEvent(event, evidenceStore: Set<string>): boolean {

  const message = canonicalize({
    eventId: event.eventId,
    entityId: event.entityId,
    payload: event.payload,
    timestamp: event.timestamp,
    evidenceHash: event.evidenceHash
  });

  const signatureValid = verifySignature(
    message,
    event.signature,
    event.publicKey
  );

  const evidenceValid = evidenceStore.has(event.evidenceHash);

  return signatureValid && evidenceValid;
}


