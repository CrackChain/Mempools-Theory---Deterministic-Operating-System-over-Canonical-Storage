8. Deterministic Feature Extraction

type IdentityFeatures = {
  success_rate: number;
  dispute_rate: number;
  volume_30d: number;
  consistency_score: number;
  anomaly_score: number;
};

function buildFeatures(events: any[]): IdentityFeatures {

  const payments = events.filter(e => e.payload?.action?.includes("payment"));

  const success = payments.filter(e => e.payload.action === "payment_success").length;
  const failures = payments.filter(e => e.payload.action === "payment_failed").length;

  const total = payments.length || 1;

  const successRate = success / total;
  const disputeRate = failures / total;

  const volume = payments.reduce((acc, e) => acc + (e.payload.amount || 0), 0);

  return {
    success_rate: successRate,
    dispute_rate: disputeRate,
    volume_30d: volume,
    consistency_score: successRate - disputeRate,
    anomaly_score: disputeRate > 0.2 ? 0.8 : 0.2
  };
}


