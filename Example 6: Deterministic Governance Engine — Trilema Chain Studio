# 14. Two-Phase Execution (Treasury-safe)

function executeProposal(proposal) {

  const hold = ledger.reserveFunds(proposal.actions);

  if (!hold.success) {
    return "failed_execution";
  }

  const result = ledger.execute(hold);

  if (!result.success) {
    return "failed_execution";
  }

  return "executed";
}

