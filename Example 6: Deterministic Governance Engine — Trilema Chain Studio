# 8. Anti-Replay + Deterministic Uniqueness

function uniqueVotes(votes) {

  const map = new Map();

  for (const v of votes) {
    const existing = map.get(v.voterId);

    if (!existing || v.timestamp > existing.timestamp) {
      map.set(v.voterId, v); // last-write-wins (deterministic)
    }
  }

  return Array.from(map.values());
}

