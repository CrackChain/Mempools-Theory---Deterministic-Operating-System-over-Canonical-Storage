# 16. State Transition Logic

function nextState(state, event, context) {

  if (event.type === "start_voting") return "voting";

  if (event.type === "close_voting") {
    const result = evaluateVotes(context);
    return result.approved ? "approved" : "rejected";
  }

  if (event.type === "execute" && state === "approved") {
    return executeProposal(context.proposal);
  }

  if (event.type === "dispute") return "disputed";

  if (event.type === "override") return "overridden";

  return state;
}

