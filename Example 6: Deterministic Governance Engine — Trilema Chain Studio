# 10. Deterministic Ordering

function orderVotes(votes) {
  return votes.sort((a, b) =>
    a.timestamp === b.timestamp
      ? a.voteId.localeCompare(b.voteId)
      : a.timestamp.localeCompare(b.timestamp)
  );
}

---

# 11. Fixed Precision Arithmetic

const SCALE = 10000;

function toFixed(n) {
  return Math.floor(n * SCALE);
}

---

# 12. Vote Evaluation (corrected)

function evaluateVotes(context) {

  const votes = orderVotes(
    uniqueVotes(context.votes)
      .filter(v => verifyVote(v))
      .filter(v => validVote(v, context.proposal))
  );

  let totalWeight = 0;
  let yesWeight = 0;

  for (const v of votes) {

    const weight = toFixed(v.score);

    totalWeight += weight;

    if (v.vote === "yes") {
      yesWeight += weight;
    }
  }

  const quorumReached =
    totalWeight >= toFixed(context.quorum * context.totalEligibleWeight);

  const approvalRatio =
    totalWeight > 0 ? yesWeight / totalWeight : 0;

  const approved =
    quorumReached &&
    approvalRatio >= context.approvalThreshold;

  return {
    quorumReached,
    approvalRatio,
    approved
  };
}

