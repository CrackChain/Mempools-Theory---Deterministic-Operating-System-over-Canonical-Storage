# 7. Trust Pipeline (strict)

function verifyVote(vote) {

  const message = canonicalize({
    proposalId: vote.proposalId,
    voterId: vote.voterId,
    vote: vote.vote,
    timestamp: vote.timestamp,
    scoreArtifactHash: vote.scoreArtifactHash
  });

  const sigValid = verifyEd25519(message, vote.signature, vote.publicKey);

  const scoreValid = verifyScoreArtifact(
    vote.scoreArtifactHash,
    vote.score,
    vote.scoringSignature
  );

  return sigValid && scoreValid;
}

