10. Deterministic Execution Engine

function executePipeline(batch, pipeline) {

  if (!verifyIngestion(batch)) {
    throw new Error("INVALID_SIGNATURE");
  }

  let workingSet = structuredClone(batch.payload);

  workingSet = workingSet
    .filter(validateSchema)
    .sort((a, b) => a.tx.localeCompare(b.tx));

  for (const step of pipeline.steps) {

    if (step.type === "filter") {
      workingSet = workingSet.filter(row => row[step.field] > step.value);
    }

    if (step.type === "map") {
      workingSet = workingSet.map(row => ({
        ...row,
        [step.field]: Math.floor(row[step.field] * step.value)
      }));
    }

    if (step.type === "aggregate") {
      const total = workingSet.reduce(
        (acc, row) => acc + BigInt(row.amount),
        BigInt(0)
      );

      workingSet = [{ total: total.toString() }];
    }
  }

  return workingSet;
}


