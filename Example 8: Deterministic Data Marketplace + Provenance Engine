7. Ingestion Trust Pipeline

function verifyIngestion(batch: DataIngestionBatch): boolean {

  const message = canonicalize({
    dataId: batch.dataId,
    source: batch.source,
    timestamp: batch.timestamp,
    payload: batch.payload
  });

  return verifyEd25519(message, batch.signature, batch.publicKey);
}


