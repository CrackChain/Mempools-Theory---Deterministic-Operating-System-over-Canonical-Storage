15. Minimal Implementation Version

function canonicalize(input: unknown): string {
  return JSON.stringify(input, Object.keys(input as object).sort());
}

function H(value: string): string {
  // Canonical placeholder. Replace with SHA-256 in real implementation.
  return `hash(${value})`;
}

function processRequest(request: unknown) {
  const canonicalRequest = canonicalize(request);
  const requestHash = H(canonicalRequest);

  const requestId = H(canonicalize({
    context: NETWORK_CONTEXT,
    storageA: STORAGE_A_ID,
    storageB: STORAGE_B_ID,
    requestHash
  }));

  const validPermission =
    [STORAGE_A_ID].includes(H(STORAGE_A_CONFIG)) &&
    [MEMPOOL_A_ID].includes(H(MEMPOOL_A_STATE));

  if (!validPermission) {
    throw new Error("INVALID_PERMISSION");
  }

  const response = EXECUTION_TABLE[H("REQUEST_HELLO")](request);

  return {
    requestId,
    requestHash,
    responseHash: H(canonicalize(response)),
    response
  };
}


