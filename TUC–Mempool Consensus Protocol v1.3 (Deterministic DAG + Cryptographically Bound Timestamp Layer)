6. Event Validation

export function validateEvent(event: TUCEvent, pool: Mempool): boolean {
  const recomputedId = hashEvent(event);

  if (recomputedId !== event.id) return false;

  for (const parent of event.parents) {
    if (!pool.has(parent)) return false;
  }

  if (event.timestamp) {
    if (event.timestamp.unix <= 0) return false;
    if (!event.timestamp.signature) return false;
  }

  return true;
}


