7. TUC-Rank (Deterministic Causal Ordering)

The ranking is purely structural over the DAG.

export function tucRank(
  id: string,
  pool: Mempool,
  memo: Map<string, number> = new Map()
): number {
  if (memo.has(id)) return memo.get(id)!;

  const node = pool.get(id);
  if (!node) return 0;

  if (node.parents.length === 0) {
    memo.set(id, 0);
    return 0;
  }

  let sum = 0;

  for (const parentId of node.parents) {
    sum += tucRank(parentId, pool, memo);
  }

  const value = 1 + (sum / node.parents.length);

  memo.set(id, value);
  return value;
}


---

8. Global Deterministic Ordering

export function deterministicOrder(pool: Mempool): TUCEvent[] {
  const memo = new Map<string, number>();

  for (const id of pool.keys()) {
    tucRank(id, pool, memo);
  }

  return [...pool.values()].sort((a, b) => {
    const ra = memo.get(a.id) ?? 0;
    const rb = memo.get(b.id) ?? 0;

    if (ra !== rb) return ra - rb;

    if (a.id === b.id) return 0;

    return a.id < b.id ? -1 : 1;
  });
}


