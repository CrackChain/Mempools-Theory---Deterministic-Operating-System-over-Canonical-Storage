10. State Compilation

export function compileState(pool: Mempool): TUCState {
  const ordered = deterministicOrder(pool);

  const heightIndex = new Map<string, number>();
  const timestampIndex = new Map<string, number>();

  ordered.forEach((event, index) => {
    heightIndex.set(event.id, index);

    if (event.timestamp) {
      timestampIndex.set(event.id, event.timestamp.unix);
    }
  });

  return {
    mempool: pool,
    ordered,
    heightIndex,
    timestampIndex
  };
}


