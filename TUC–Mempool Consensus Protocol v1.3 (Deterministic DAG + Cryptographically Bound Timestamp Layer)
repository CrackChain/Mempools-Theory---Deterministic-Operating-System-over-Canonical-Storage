4. Canonical Event Hash

import crypto from "crypto";

export function hashEvent(event: Omit<TUCEvent, "id">): string {
  const { payload, parents, signer, nonce } = event;

  const normalized = {
    payload,
    parents: [...parents].sort(),
    signer,
    nonce
  };

  const canonical = canonicalSerialize(normalized);

  return crypto.createHash("sha256").update(canonical).digest("hex");
}


