12. TUC-Time (Logical Time)

export function TUC_TIME(eventId: string, state: TUCState): number {
  return state.heightIndex.get(eventId) ?? -1;
}


---

13. TUC-Timestamp (Observational Time)

export function TUC_TS(eventId: string, state: TUCState): number {
  return state.timestampIndex.get(eventId) ?? -1;
}


