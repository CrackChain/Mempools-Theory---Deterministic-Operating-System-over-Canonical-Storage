11. Cryptographic Timestamp Verification

The timestamp is bound to:

event.id

timestamp.unix

timestamp.source

signer identity


import crypto from "crypto";

export function verifyTimestamp(event: TUCEvent): boolean {
  if (!event.timestamp) return true;

  const base = `${event.id}:${event.timestamp.unix}:${event.timestamp.source}`;

  const expected = crypto.createHash("sha256").update(base).digest("hex");

  const signerBound = crypto
    .createHash("sha256")
    .update(event.signer + expected)
    .digest("hex");

  return event.timestamp.signature === signerBound;
}


