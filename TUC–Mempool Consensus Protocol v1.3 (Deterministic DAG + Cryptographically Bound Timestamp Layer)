3. Strict Deterministic Canonicalization

Canonicalization is structural, typed, and recursive.

export function canonicalSerialize(value: unknown): string {
  if (value === null) return "n";

  const t = typeof value;

  if (t === "string") return `s:${value}`;
  if (t === "number") return `i:${value}`;
  if (t === "boolean") return `b:${value}`;

  if (Array.isArray(value)) {
    return `a:[${value.map(canonicalSerialize).join("|")}]`;
  }

  if (t === "object") {
    const obj = value as Record<string, unknown>;
    const keys = Object.keys(obj).sort();

    return `o:{${keys
      .map(k => `${k}:${canonicalSerialize(obj[k])}`)
      .join("|")}}`;
  }

  throw new Error(`Unsupported type: ${t}`);
}


