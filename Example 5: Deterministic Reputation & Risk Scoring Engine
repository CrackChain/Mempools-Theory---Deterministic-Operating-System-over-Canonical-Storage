6. Temporal decay (anti-gaming + realism)

function decayWeight(eventTs: string, anchorTs: string): number {
  const ageDays =
    (Date.parse(anchorTs) - Date.parse(eventTs)) / (1000 * 60 * 60 * 24);
  return Math.exp(-0.05 * ageDays); // tunable decay
}


