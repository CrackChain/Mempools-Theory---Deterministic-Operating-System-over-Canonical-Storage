9. Scoring model (unchanged but validated)

export function evaluateModelV1(f: FeatureVector): number {
  const score =
    0.25 * f.weighted_success_rate +
    0.20 * (1 - f.weighted_chargeback_rate) +
    0.15 * (1 - f.weighted_dispute_loss_rate) +
    0.15 * f.contract_fulfillment_rate +
    0.10 * (1 - f.breach_rate) +
    0.15 * f.identity_trust_level;

  return Math.min(Math.max(score, 0), 1);
}


