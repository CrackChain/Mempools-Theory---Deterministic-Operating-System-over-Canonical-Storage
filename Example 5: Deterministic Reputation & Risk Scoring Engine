8. Deterministic feature builder (corrected)

export function buildFeatures(
  events: VerifiedEvent[],
  anchorTimestamp: string
): FeatureVector {

  const lowerBound = new Date(
    Date.parse(anchorTimestamp) - 30 * 24 * 60 * 60 * 1000
  ).toISOString();

  const verified = events
    .filter(verifyEvent)
    .sort((a, b) => a.timestamp.localeCompare(b.timestamp));

  const windowed = verified.filter(e =>
    withinWindow(e.timestamp, lowerBound, anchorTimestamp)
  );

  const payments = windowed.filter(e => e.type === "payment");
  const disputes = windowed.filter(e => e.type === "dispute");
  const contracts = windowed.filter(e => e.type === "contract");

  let totalWeight = 0;
  let successWeight = 0;
  let chargebackWeight = 0;

  let totalVolume = 0;

  for (const p of payments) {
    const weight = decayWeight(p.timestamp, anchorTimestamp);
    totalWeight += weight;

    const amount = Number(p.payload["amount"] ?? 0);
    totalVolume += amount;

    if (p.payload["status"] === "settled") {
      successWeight += weight;
    }

    if (p.payload["status"] === "chargeback") {
      chargebackWeight += weight;
    }
  }

  const weightedSuccessRate = totalWeight > 0 ? successWeight / totalWeight : 1;
  const weightedChargebackRate = totalWeight > 0 ? chargebackWeight / totalWeight : 0;

  const lostDisputes = disputes.filter(d => d.payload["result"] === "merchant_lost").length;
  const disputeLossRate = disputes.length > 0 ? lostDisputes / disputes.length : 0;

  const fulfilled = contracts.filter(c => c.payload["finalState"] === "fulfilled").length;
  const breached = contracts.filter(c => c.payload["finalState"] === "breached").length;

  const fulfillmentRate = contracts.length > 0 ? fulfilled / contracts.length : 1;
  const breachRate = contracts.length > 0 ? breached / contracts.length : 0;

  const identityTrustLevel =
    verified.length > 0 ? Math.min(1, verified.length / 1000) : 0.5;

  return {
    total_volume_30d: totalVolume,
    weighted_success_rate: weightedSuccessRate,
    weighted_chargeback_rate: weightedChargebackRate,
    weighted_dispute_loss_rate: disputeLossRate,
    contract_fulfillment_rate: fulfillmentRate,
    breach_rate: breachRate,
    identity_trust_level: identityTrustLevel,
    sample_size: verified.length
  };
}


