11. Score artifact (properly signed)

export function generateScoreArtifact(
  entityId: string,
  features: FeatureVector,
  anchorTimestamp: string,
  privateKeyHex: string
) {

  const score = evaluateModelV1(features);
  const confidence = computeConfidence(features);

  const featuresHash = sha256(canonicalize(features));

  let riskLevel: "low" | "medium" | "high" = "low";
  if (score < 0.5) riskLevel = "high";
  else if (score < 0.8) riskLevel = "medium";

  const artifact = {
    entityId,
    model: "risk_score",
    version: "v1",
    score: Number(score.toFixed(4)),
    riskLevel,
    confidence,
    featuresHash,
    timestamp: anchorTimestamp
  };

  const artifactHash = sha256(canonicalize(artifact));

  const signature = signEd25519(artifactHash, privateKeyHex);

  return {
    ...artifact,
    signature
  };
}


