10. Confidence model (real)

function computeConfidence(f: FeatureVector): number {
  const base = Math.min(1, f.sample_size / 500); // saturation
  const volumeFactor = Math.min(1, f.total_volume_30d / 100000);
  return 0.5 * base + 0.5 * volumeFactor;
}


