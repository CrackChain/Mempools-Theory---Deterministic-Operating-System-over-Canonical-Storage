3. Canonicalization Layer (deterministic invariant)

export function canonicalize(value: unknown): string {
  if (value === null || typeof value !== "object") {
    return JSON.stringify(value);
  }

  if (Array.isArray(value)) {
    return `[${value.map(canonicalize).join(",")}]`;
  }

  const obj = value as Record<string, unknown>;
  const keys = Object.keys(obj).sort();

  return `{${keys.map(k => `"${k}":${canonicalize(obj[k])}`).join(",")}}`;
}

export function sha256(input: string): string {
  return crypto.createHash("sha256").update(input).digest("hex");
}


---

4. Cryptographic Event Verification Layer

> Note: This is a deterministic integrity check (not a full cryptographic signature implementation).



export function verifyEvent(event: KernelEvent): boolean {
  const message = canonicalize({
    eventId: event.eventId,
    type: event.type,
    entityId: event.entityId,
    payload: event.payload,
    timestamp: event.timestamp,
    previousEventHash: event.previousEventHash,
    evidenceHash: event.evidenceHash
  });

  const expected = sha256(`${event.publicKey}:${message}`);
  return expected === event.signature;
}


